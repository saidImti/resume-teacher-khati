# ============================================================
# RÉSUMÉ TEACHER KHATI — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans git
# ============================================================

# ─── SUPABASE ───────────────────────────────────────────────
# Récupérer sur : https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...votre-cle-anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...votre-cle-service-role...

# ─── OPENAI ─────────────────────────────────────────────────
# Récupérer sur : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...votre-cle-openai...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# ─── N8N (HOSTINGER) ────────────────────────────────────────
# URL de votre instance N8N Hostinger
N8N_BASE_URL=https://votre-instance.n8n.hostinger.com
# Token d'authentification N8N (dans N8N → Settings → API)
N8N_API_KEY=votre-cle-n8n
# Secret partagé pour sécuriser les webhooks Next.js → N8N
N8N_WEBHOOK_SECRET=votre-secret-aleatoire-32-chars

# ─── WHATSAPP BUSINESS API (Phase 5) ────────────────────────
# Récupérer sur : https://developers.facebook.com
WHATSAPP_API_TOKEN=votre-token-whatsapp
WHATSAPP_PHONE_NUMBER_ID=votre-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=votre-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=votre-token-verification-webhook

# ─── APPLICATION ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Résumé Teacher Khati
# next-auth secret (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET=votre-secret-nextauth
