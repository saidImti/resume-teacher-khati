# Resume Teacher Khati - environment variables
# Copy to .env.local for local development.
# Never commit real secrets.

# Supabase
# Project URL only. Do not add /rest/v1, /auth/v1, or a trailing slash.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Browser-safe key: use sb_publishable_... or the legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only key: use sb_secret_... or the legacy service_role JWT.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# Optional integrations
PADLET_API_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEST_PHONE=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Resume Teacher Khati
