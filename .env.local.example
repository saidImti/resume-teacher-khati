# Supabase
# Project URL only. Do not add /rest/v1, /auth/v1, or a trailing slash.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Browser-safe key: use the new sb_publishable_... key, or the legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only key: use the new sb_secret_... key, or the legacy service_role JWT.
# Never expose this value in browser code, logs, screenshots, or committed files.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Optional integrations
PADLET_API_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEST_PHONE=

# Pinterest API (developers.pinterest.com)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
