# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtenir sur : https://supabase.com/dashboard → Votre projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key (jamais exposée côté client — uniquement server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Obtenir sur : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── N8N (Phase 4-5) ──────────────────────────────────────────────────────────
# URL de votre instance N8N sur Hostinger
N8N_WEBHOOK_URL=https://n8n.votredomaine.com/webhook
N8N_API_KEY=votre_cle_api_n8n

# ─── WhatsApp Business API (Phase 5) ──────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
